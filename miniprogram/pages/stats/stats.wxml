<!-- 趋势统计页 -->
<view class="container">
  <!-- 时间范围切换 -->
  <view class="card range-card">
    <view class="range-tabs">
      <view
        class="range-tab {{range === 7 ? 'active' : ''}}"
        bindtap="switchRange"
        data-range="7"
      >近7天</view>
      <view
        class="range-tab {{range === 14 ? 'active' : ''}}"
        bindtap="switchRange"
        data-range="14"
      >近14天</view>
      <view
        class="range-tab {{range === 30 ? 'active' : ''}}"
        bindtap="switchRange"
        data-range="30"
      >近30天</view>
    </view>
  </view>

  <!-- 统计概览 -->
  <view class="card overview-card">
    <view class="overview-row">
      <view class="overview-item">
        <text class="overview-value">{{overview.totalCount}}</text>
        <text class="overview-label">总次数</text>
      </view>
      <view class="overview-item">
        <text class="overview-value">{{overview.totalDays}}</text>
        <text class="overview-label">记录天数</text>
      </view>
      <view class="overview-item">
        <text class="overview-value">{{overview.totalSessions}}</text>
        <text class="overview-label">记录次数</text>
      </view>
      <view class="overview-item">
        <text class="overview-value">{{overview.avgPerSession}}</text>
        <text class="overview-label">胎动次均</text>
      </view>
      <view class="overview-item">
        <text class="overview-value">{{overview.maxAvgPerSession}}</text>
        <text class="overview-label">单日最高次均</text>
      </view>
      <view class="overview-item">
        <text class="overview-value">{{overview.minAvgPerSession}}</text>
        <text class="overview-label">单日最低次均</text>
      </view>
    </view>
  </view>

  <!-- 柱状图 -->
  <view class="card chart-card">
    <view class="chart-header">
      <view class="chart-title">每日胎动趋势</view>
      <view class="chart-legend">
        <view class="legend-item">
          <text class="legend-text legend-top">柱上:总次数</text>
        </view>
        <view class="legend-item">
          <text class="legend-text legend-inner">柱内:次均</text>
        </view>
      </view>
    </view>
    <scroll-view class="chart-container" scroll-x="true" enhanced="true" show-scrollbar="true">
      <view class="chart-bars">
        <view
          class="chart-bar-wrapper"
          wx:for="{{chartData}}"
          wx:key="date"
        >
          <view class="chart-value">{{item.totalCount || ''}}</view>
          <view class="chart-bar-area">
            <view
              class="chart-bar"
              style="height: {{item.barHeight}}rpx"
            >
              <view class="chart-bar-fill {{item.totalCount < 3 && item.totalCount > 0 ? 'bar-warning' : ''}}">
                <!-- 次均数字嵌在柱子内部底部 -->
                <view class="chart-avg-label" wx:if="{{item.dayAvg}}">{{item.dayAvg}}</view>
              </view>
            </view>
          </view>
          <view class="chart-date">{{item.shortDate}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 每日明细 -->
  <view class="card detail-card">
    <view class="detail-title">每日明细</view>
    <view class="detail-list">
      <view class="detail-item" wx:for="{{dailyStats}}" wx:key="date">
        <text class="detail-date">{{item.date}}</text>
        <view class="detail-bar-bg">
          <view
            class="detail-bar-fill"
            style="width: {{item.barWidth}}%"
          ></view>
        </view>
        <text class="detail-count">{{item.totalCount}}次</text>
      </view>
    </view>
  </view>
</view>
