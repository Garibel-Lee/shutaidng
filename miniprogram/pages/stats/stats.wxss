/* 时间范围 */
.range-card {
  padding: 20rpx;
}

.range-tabs {
  display: flex;
  justify-content: space-around;
}

.range-tab {
  padding: 12rpx 36rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #999;
  background: #f5f5f5;
}

.range-tab.active {
  background: linear-gradient(135deg, #FF8FA0, #FF6B81);
  color: #fff;
  font-weight: 500;
}

/* 概览卡片 */
.overview-card {
  padding: 30rpx;
}

.overview-row {
  display: flex;
  justify-content: space-around;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #FF6B81;
}

.overview-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 柱状图 */
.chart-card {
  padding: 30rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.chart-container {
  width: 100%;
  overflow-x: auto;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  min-height: 300rpx;
  padding: 0 10rpx;
}

.chart-bar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  min-width: 40rpx;
}

.chart-value {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 8rpx;
  min-height: 28rpx;
}

.chart-bar {
  width: 32rpx;
  border-radius: 16rpx 16rpx 0 0;
  overflow: hidden;
  min-height: 4rpx;
}

.chart-bar-fill {
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #FF8FA0, #FF6B81);
  border-radius: 16rpx 16rpx 0 0;
}

.chart-bar-fill.bar-warning {
  background: linear-gradient(180deg, #FFB74D, #FF9800);
}

.chart-date {
  font-size: 20rpx;
  color: #ccc;
  margin-top: 8rpx;
  white-space: nowrap;
}

/* 每日明细 */
.detail-card {
  padding: 30rpx;
}

.detail-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
}

.detail-date {
  font-size: 24rpx;
  color: #666;
  width: 140rpx;
  flex-shrink: 0;
}

.detail-bar-bg {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.detail-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF8FA0, #FF6B81);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.detail-count {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
  width: 80rpx;
  text-align: right;
  flex-shrink: 0;
}
