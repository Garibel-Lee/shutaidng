/* 时间范围 */
.range-card {
  padding: 24rpx;
}

.range-tabs {
  display: flex;
  justify-content: space-around;
}

.range-tab {
  padding: 14rpx 40rpx;
  border-radius: 30rpx;
  font-size: 30rpx;
  color: #999;
  background: #f5f5f5;
}

.range-tab.active {
  background: linear-gradient(135deg, #FF8FA0, #FF6B81);
  color: #fff;
  font-weight: 500;
}

/* 概览卡片 */
.overview-card {
  padding: 36rpx;
}

.overview-row {
  display: flex;
  justify-content: space-around;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #FF6B81;
}

.overview-label {
  font-size: 28rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 柱状图 */
.chart-card {
  padding: 32rpx;
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.chart-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.chart-legend {
  display: flex;
  gap: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-text {
  font-size: 22rpx;
  color: #999;
}

.legend-top {
  color: #FF6B81;
}

.legend-inner {
  color: #fff;
  background: #FF8FA0;
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
}

.chart-container {
  width: 100%;
  overflow-x: auto;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  min-height: 320rpx;
  padding: 0 10rpx;
}

.chart-bar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  min-width: 44rpx;
}

.chart-value {
  font-size: 24rpx;
  color: #FF6B81;
  font-weight: 500;
  margin-bottom: 8rpx;
  min-height: 32rpx;
}

.chart-bar-area {
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  width: 100%;
  min-height: 260rpx;
}

.chart-bar {
  width: 32rpx;
  border-radius: 16rpx 16rpx 0 0;
  overflow: visible;
  min-height: 4rpx;
}

.chart-bar-fill {
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #FF8FA0, #FF6B81);
  border-radius: 16rpx 16rpx 0 0;
  position: relative;
  overflow: visible;
}

.chart-bar-fill.bar-warning {
  background: linear-gradient(180deg, #FFB74D, #FF9800);
}

/* 柱内次均标签 */
.chart-avg-label {
  position: absolute;
  bottom: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
  white-space: nowrap;
}

.chart-date {
  font-size: 24rpx;
  color: #bbb;
  margin-top: 10rpx;
  white-space: nowrap;
}

/* 每日明细 */
.detail-card {
  padding: 32rpx;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 14rpx 0;
}

.detail-date {
  font-size: 28rpx;
  color: #666;
  width: 150rpx;
  flex-shrink: 0;
}

.detail-bar-bg {
  flex: 1;
  height: 20rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
  overflow: hidden;
}

.detail-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF8FA0, #FF6B81);
  border-radius: 10rpx;
  transition: width 0.3s ease;
}

.detail-count {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  width: 90rpx;
  text-align: right;
  flex-shrink: 0;
}
