/* 强制登录引导 */
.login-gate {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-card {
  width: 600rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 60rpx 48rpx;
  text-align: center;
}

.login-icon {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 50%;
  background: #FFF3E0;
  color: #FF9800;
  font-size: 48rpx;
  font-weight: 700;
  margin: 0 auto 24rpx;
}

.login-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.login-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
  margin-bottom: 36rpx;
}

.login-confirm-btn {
  width: 100%;
  margin-top: 24rpx;
}

/* 用户昵称 */
.user-card {
  padding: 24rpx 30rpx;
}

.user-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.user-greeting {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.user-edit {
  font-size: 24rpx;
  color: #FF8FA0;
  padding: 8rpx 20rpx;
}

.nickname-btn {
  font-size: 26rpx;
  color: #fff;
  background: linear-gradient(135deg, #FF8FA0, #FF6B81);
  border: none;
  border-radius: 30rpx;
  padding: 8rpx 32rpx;
  line-height: 1.8;
}

/* 昵称弹窗 */
.nickname-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nickname-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.nickname-dialog {
  position: relative;
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  z-index: 1;
}

.nickname-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 36rpx;
}

.nickname-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  margin-bottom: 36rpx;
}

.nickname-actions {
  display: flex;
  gap: 20rpx;
}

.nickname-actions .btn-secondary {
  flex: 1;
  text-align: center;
}

.nickname-confirm {
  flex: 1;
  padding: 16rpx 0;
  font-size: 28rpx;
}

/* 方法选择 */
.method-card {
  padding: 24rpx;
}

.method-tabs {
  display: flex;
  justify-content: space-around;
  margin-bottom: 16rpx;
}

.method-tab {
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #999;
  background: #f5f5f5;
  transition: all 0.3s;
}

.method-tab.active {
  background: linear-gradient(135deg, #FF8FA0, #FF6B81);
  color: #fff;
  font-weight: 500;
}

.method-desc {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 计数显示 */
.count-display {
  text-align: center;
  padding: 40rpx 30rpx;
}

.count-main {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 12rpx;
}

.count-number {
  font-size: 120rpx;
  font-weight: 700;
  color: #FF6B81;
  line-height: 1;
}

.count-label {
  font-size: 32rpx;
  color: #FF8FA0;
  font-weight: 500;
}

.count-sub {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #999;
}

.count-divider {
  color: #ddd;
}

.timer-text {
  font-family: 'Courier New', monospace;
  font-size: 28rpx;
}

/* 大按钮 */
.button-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 40rpx 0;
}

.big-button {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #FFB3C1, #FF6B81);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 129, 0.4);
  position: relative;
  overflow: hidden;
  transition: transform 0.15s ease;
}

.big-button.active {
  background: linear-gradient(145deg, #FF8FA0, #E84666);
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 129, 0.5);
}

.big-button.tapping {
  transform: scale(0.92);
}

.big-button-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #FF6B81, #FF8FA0);
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.big-button.active .big-button-inner {
  background: linear-gradient(145deg, #E84666, #FF6B81);
}

.big-button-text {
  color: #fff;
  font-size: 40rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}

/* 涟漪效果 */
.ripple {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  animation: ripple-effect 0.6s ease-out;
}

@keyframes ripple-effect {
  from {
    transform: scale(0.5);
    opacity: 1;
  }
  to {
    transform: scale(1.5);
    opacity: 0;
  }
}

/* 提示文字 */
.tap-hint {
  margin-top: 24rpx;
  font-size: 26rpx;
  text-align: center;
  min-height: 40rpx;
}

.hint-new {
  color: #4CAF50;
}

.hint-same {
  color: #FF9800;
}

/* 操作栏 */
.action-bar {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

/* 结果卡片 */
.result-card {
  border-left: 8rpx solid #FF8FA0;
}

.result-header {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.result-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.result-label {
  color: #999;
  font-size: 28rpx;
}

.result-value {
  font-weight: 600;
  font-size: 28rpx;
  color: #333;
}

.result-status {
  text-align: center;
  padding: 16rpx;
  margin-top: 16rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.status-normal {
  background: #E8F5E9;
  color: #4CAF50;
}

.status-warning {
  background: #FFF3E0;
  color: #FF9800;
}

.status-danger {
  background: #FFEBEE;
  color: #F44336;
}

/* 今日统计 */
.today-card {
  text-align: center;
}

.today-header {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.today-count {
  font-size: 56rpx;
  font-weight: 700;
  color: #FF6B81;
}

.today-sessions {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 4rpx;
}
