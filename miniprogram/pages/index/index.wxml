<!-- 计数主页 -->
<view class="container">
  <!-- 强制登录引导（未设置昵称时遮罩显示） -->
  <view class="login-gate" wx:if="{{showLoginGate}}">
    <view class="login-card">
      <view class="login-icon">!</view>
      <view class="login-title">请先设置昵称</view>
      <view class="login-desc">设置昵称后数据将同步到云端，确保不会丢失。未登录的数据仅保存在本地，退出后将无法恢复。</view>
      <input
        class="nickname-input"
        type="nickname"
        placeholder="点击获取微信昵称"
        value="{{nicknameInput}}"
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
      />
      <button class="btn-primary login-confirm-btn" bindtap="onConfirmNickname">确认并开始</button>
    </view>
  </view>

  <!-- 用户昵称 -->
  <view class="card user-card" wx:if="{{nickname}}">
    <view class="user-info">
      <text class="user-greeting">{{nickname}}，记得数胎动哦</text>
      <text class="user-edit" bindtap="onEditNickname">修改</text>
    </view>
  </view>

  <!-- 昵称修改弹窗 -->
  <view class="nickname-modal" wx:if="{{showNicknameModal}}">
    <view class="nickname-mask" bindtap="onCancelNickname"></view>
    <view class="nickname-dialog">
      <view class="nickname-title">修改昵称</view>
      <input
        class="nickname-input"
        type="nickname"
        placeholder="请输入昵称"
        value="{{nicknameInput}}"
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
      />
      <view class="nickname-actions">
        <button class="btn-secondary" bindtap="onCancelNickname">取消</button>
        <button class="btn-primary nickname-confirm" bindtap="onUpdateNickname">确定</button>
      </view>
    </view>
  </view>

  <!-- 方法选择 -->
  <view class="card method-card">
    <view class="method-tabs">
      <view
        class="method-tab {{currentMethod === 'one_hour' ? 'active' : ''}}"
        bindtap="switchMethod"
        data-method="one_hour"
      >1小时法</view>
      <view
        class="method-tab {{currentMethod === 'two_hour' ? 'active' : ''}}"
        bindtap="switchMethod"
        data-method="two_hour"
      >2小时法</view>
      <view
        class="method-tab {{currentMethod === 'cardiff' ? 'active' : ''}}"
        bindtap="switchMethod"
        data-method="cardiff"
      >Cardiff法</view>
    </view>
    <view class="method-desc">{{methodDesc}}</view>
  </view>

  <!-- 计数显示区 -->
  <view class="count-display card">
    <view class="count-main">
      <text class="count-number">{{realCount}}</text>
      <text class="count-label">次胎动</text>
    </view>
    <view class="count-sub">
      <text class="tap-count">点击 {{tapCount}} 次</text>
      <text class="count-divider">|</text>
      <text class="timer-text">{{timerText}}</text>
    </view>
  </view>

  <!-- 大按钮 -->
  <view class="button-area">
    <view
      class="big-button {{isActive ? 'active' : ''}} {{tapping ? 'tapping' : ''}}"
      bindtap="onTapButton"
    >
      <view class="big-button-inner">
        <text class="big-button-text" wx:if="{{!isActive}}">开始计数</text>
        <text class="big-button-text big-button-text-active" wx:elif="{{isActive}}">宝宝动了</text>
      </view>
      <view class="ripple" wx:if="{{tapping}}"></view>
    </view>

    <!-- 悬浮提示 -->
    <view class="float-toast {{showFloatToast ? 'show' : ''}} {{lastTapIsNew ? 'toast-new' : 'toast-same'}}" wx:if="{{lastTapHint}}">
      <text>{{lastTapHint}}</text>
    </view>
  </view>

  <!-- 操作栏 -->
  <view class="action-bar" wx:if="{{isActive}}">
    <button class="btn-secondary" bindtap="onEndSession">结束计数</button>
  </view>

  <!-- 结果展示 -->
  <view class="result-card card" wx:if="{{showResult}}">
    <view class="result-header">本次计数结果</view>
    <view class="result-content">
      <view class="result-row">
        <text class="result-label">真实胎动</text>
        <text class="result-value">{{resultCount}} 次</text>
      </view>
      <view class="result-row">
        <text class="result-label">用时</text>
        <text class="result-value">{{resultDuration}}</text>
      </view>
      <view class="result-status status-{{resultStatus}}">
        {{resultMessage}}
      </view>
    </view>
  </view>

  <!-- 今日统计 -->
  <view class="card today-card" wx:if="{{todayCount > 0}}">
    <view class="today-header">今日胎动</view>
    <view class="today-count">{{todayCount}} 次</view>
    <view class="today-sessions">共 {{todaySessions}} 次记录</view>
  </view>
</view>
